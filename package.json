{
  "name": "cmsc129-lab4-task-manager",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:backend": "node backend/server.js",
    "dev:frontend": "vite",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "vite build",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration --passWithNoTests",
    "test:system": "playwright test --pass-with-no-tests",
    "test": "npm run test:unit && npm run test:integration && npm run test:system",
    "start": "node backend/server.js"
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supertest": "^7.0.0",
    "vite": "^7.0.0"
  }
}
